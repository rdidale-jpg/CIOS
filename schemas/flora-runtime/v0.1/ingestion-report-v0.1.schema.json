      "completed_at": "2026-07-19T00:00:02Z",
      "schema_version": "0.1.0",
      "object_count": 17,
      "relationship_count": 9,
      "evidence_count": 3,
      "observation_count": 5,
      "unknown_count": 1,
      "contradiction_count": 1,
      "accepted_count": 17,
      "rejected_count": 0,
      "unresolved_identity_count": 0,
      "collision_count": 0,
      "warning_count": 1,
      "validation_failures": [],
      "safe_unavailable_causes": [],
      "resulting_projection_version": "0.1.0"
    }
  ]
