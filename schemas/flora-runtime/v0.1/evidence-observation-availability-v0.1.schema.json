{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cios.local/schemas/flora-runtime/v0.1/evidence-observation-availability-v0.1.schema.json",
  "title": "Evidence Observation Availability V0.1",
  "identifier": "evidence-observation-availability-v0.1",
  "version": "0.1.0",
  "description": "Counts and retrieval availability for governed Evidence and Observations.",
  "type": "object",
  "required": [
    "focus_object_id",
    "evidence_count",
    "observation_count",
    "accepted_observation_count",
    "inaccessible_count",
    "unavailable_count"
  ],
  "properties": {
    "focus_object_id": {
      "type": "string"
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0
    },
    "observation_count": {
      "type": "integer",
      "minimum": 0
    },
    "accepted_observation_count": {
      "type": "integer",
      "minimum": 0
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "freshness_summary": {
      "type": "string"
    },
    "authority_summary": {
      "type": "string"
    },
    "lineage_coverage": {
      "enum": [
        "complete",
        "partial",
        "none",
        "unknown"
      ]
    },
    "inaccessible_count": {
      "type": "integer",
      "minimum": 0
    },
    "unavailable_count": {
      "type": "integer",
      "minimum": 0
    },
    "page": {
      "type": "object",
      "additionalProperties": true
    },
    "safe_unavailable_notices": {
      "type": "array",
      "items": {
        "$ref": "common-definitions.schema.json#/$defs/SafeNotice"
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "focus_object_id": "BRH-003",
      "evidence_count": 3,
      "observation_count": 5,
      "accepted_observation_count": 5,
      "candidate_count": 0,
      "freshness_summary": "Source package lineage is complete; individual observation freshness dates vary or are absent.",
      "authority_summary": "BRH-003 is Candidate in EK-BANK-RHYP-001; observations used by existing Banking runtime are governed presentation inputs.",
      "lineage_coverage": "partial",
      "inaccessible_count": 0,
      "unavailable_count": 0,
      "page": {
        "limit": 25,
        "cursor": null,
        "has_more": false
      },
      "safe_unavailable_notices": []
    }
  ]
}
