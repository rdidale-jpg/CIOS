{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cios.local/schemas/flora-runtime/v0.1/lineage-response-v0.1.schema.json",
  "title": "Lineage Response V0.1",
  "identifier": "lineage-response-v0.1",
  "version": "0.1.0",
  "description": "Inspectable lineage back to governed source.",
  "type": "object",
  "required": [
    "requested_object_id",
    "lineage_nodes",
    "lineage_edges",
    "completeness_status"
  ],
  "properties": {
    "requested_object_id": {
      "type": "string"
    },
    "lineage_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "node_type"
        ],
        "properties": {
          "node_id": {
            "type": "string"
          },
          "node_type": {
            "enum": [
              "source",
              "evidence",
              "observation",
              "governed_object",
              "relationship",
              "projection"
            ]
          },
          "source_asset_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "authority_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "lifecycle_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          },
          "valid_from": {
            "type": [
              "string",
              "null"
            ]
          },
          "valid_to": {
            "type": [
              "string",
              "null"
            ]
          },
          "provenance_reference": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "lineage_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "edge_type"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "edge_type": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "unavailable_segments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "access_redacted_segments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completeness_status": {
      "enum": [
        "complete",
        "partial",
        "access_redacted",
        "safe_unavailable"
      ]
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "requested_object_id": "BRH-003",
      "lineage_nodes": [
        {
          "node_id": "SRC-zip-market-participant",
